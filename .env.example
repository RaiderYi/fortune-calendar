# 本地开发：复制本文件为 `.env.local`（已被 .gitignore 忽略），填入真实值。
# 注意：Vite 不会把此变量注入前端；AI 请求由后端 Python（api）读取环境变量。

# 前端可选：Google Analytics 4（需在 Vercel 为 Frontend 构建配置同名变量）
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# DeepSeek（AI 聊天 / 解梦 / 塔罗 / 易经解读等）
DEEPSEEK_API_KEY=

# 可选：本地认证 / KV / 邮件（见 AGENTS.md、docs/VERCEL_DEPLOYMENT_GUIDE.md）
# JWT_SECRET=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# RESEND_API_KEY=
